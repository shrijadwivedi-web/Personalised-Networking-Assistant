# Copy this file to .env and fill in real values before running in any
# shared or production-like environment. Never commit a real .env file --
# it's already excluded via .gitignore.
#
# None of these are required for local development: every one of them has
# a safe default for running on your own machine. SECRET_KEY is the only
# one you MUST change before deploying anywhere other than your own laptop.

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------

# Secret key used to sign JWT access tokens. MUST be overridden with a long,
# random value in any real deployment -- anyone who knows this value can
# forge valid login tokens for any user.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=INSECURE-DEV-ONLY-CHANGE-ME

# How long an issued JWT access token remains valid, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database connection string. Defaults to a local SQLite file at
# ./data/app.db if not set. To use Postgres instead, e.g.:
#   DATABASE_URL=postgresql://user:password@localhost:5432/networking_assistant
# (and add psycopg2-binary to requirements.txt).
DATABASE_URL=sqlite:///./data/app.db

# Google Gemini API key, used for conversation generation (see
# app/services/topic_generator.py). Required for that one feature --
# theme extraction (DistilBERT) runs locally and does NOT need this.
# Without a valid key, /generate-conversation will return a 503
# "temporarily unavailable" until one is set; the rest of the app (auth,
# profile, history, feedback, fact-check) is unaffected.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override which Gemini model is used for conversation
# generation. Defaults to gemini-2.5-flash if not set.
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Frontend (Streamlit)
# ---------------------------------------------------------------------------

# Where the Streamlit frontend should look for the backend API.
# Local (no Docker): http://127.0.0.1:8000
# Docker Compose:    http://backend:8000  (set automatically in docker-compose.yml)
BACKEND_URL=http://127.0.0.1:8000
